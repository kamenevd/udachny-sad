# URL Convex-деплоя (из вывода npx convex dev)
# TODO(PLAN7): убрать после завершения миграции на PocketBase (этап D)
VITE_CONVEX_URL=

# Включить Google OAuth (true = показывать кнопку входа через Google)
# TODO(PLAN7): Google отключается полностью — см. VITE_POCKETBASE_URL ниже
VITE_GOOGLE_ENABLED=false

# Google OAuth Client ID (нужен только если VITE_GOOGLE_ENABLED=true)
# Получить: Google Cloud Console → Credentials → OAuth 2.0 Client ID
VITE_CONVEX_AUTH_google_CLIENT_ID=

# ── PLAN7: PocketBase (замена Convex) ──────────────────────────────────
# URL PocketBase-инстанса (задача A.1/A.5)
VITE_POCKETBASE_URL=https://pb.kdnfx.space

# Имя Telegram-бота для Login Widget (без @), задача B.1 — TODO: получить
# через @BotFather (ручное действие, не автоматизируется агентом)
VITE_TELEGRAM_BOT_USERNAME=

# Яндекс OAuth настраивается в PocketBase admin UI (задача B.3), клиентских
# переменных на фронте не требует — см. README-PocketBase.md
